@{
    ViewData["Title"] = "Home";
    ViewData["Page"] = "home";
}

<!-- HERO SECTION -->
<div class="hero-section">
    <div class="hero-con">
        <div class="hero-head">
            <div class="hero-logo">
                <img src="~/brand/logo.png" alt="">
            </div>

            <div class="hero-head-para">
                <p class="hero-heading">Create and Customize your <span class="primary-main-text">Keychain</span></p>
                <p class="hero-subhead">Where moments become memories you can carry</p>
            </div>
        </div>

        <div class="hero-body">
            <div class="hero-keychain">
                <img src="~/img/keychain.png" alt="keychain">
            </div>

            <button class="primary-main-button hero-button"> 
               <a href="#createSection">Create Now!</a>
            </button>
        </div>
    </div>

</div>

